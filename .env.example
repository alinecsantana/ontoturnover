# ============================================================
# CEREBRO CORPORATIVO IA - Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha os valores

# ----------------------------------------------------------
# AUTH - Microsoft Entra ID (Azure AD / Office 365)
# ----------------------------------------------------------
# Obtenha no portal: https://portal.azure.com > App Registrations
AZURE_AD_CLIENT_ID=seu-client-id-aqui
AZURE_AD_CLIENT_SECRET=seu-client-secret-aqui
AZURE_AD_TENANT_ID=seu-tenant-id-aqui

# URL base da aplicação
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32

# ----------------------------------------------------------
# CLAUDE ENTERPRISE - Anthropic
# ----------------------------------------------------------
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------
# GEMINI ENTERPRISE - Google Workspace / Vertex AI
# ----------------------------------------------------------
# Obtenha via Google Cloud Console > Vertex AI
GOOGLE_GEMINI_API_KEY=AIza...

# ----------------------------------------------------------
# COPILOT ENTERPRISE - Microsoft Azure OpenAI
# ----------------------------------------------------------
# Obtenha no Azure Portal > Azure OpenAI Service
AZURE_OPENAI_API_KEY=sua-chave-aqui
AZURE_OPENAI_ENDPOINT=https://seu-recurso.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ----------------------------------------------------------
# BANCO DE DADOS (automático, SQLite local)
# ----------------------------------------------------------
# DATABASE_PATH=./data/cerebro.db  (padrão, não precisa alterar)
