        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/vt417960/ontologies/2024/0/ontoturnover#isConsequenceEmployee"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/vt417960/ontologies/2024/0/ontoturnover#Involuntary_Turnover"/>
            </owl:Restriction>
        </owl:equivalentClass>
