        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/vt417960/ontologies/2024/0/ontoturnover#causedBy"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/vt417960/ontologies/2024/0/ontoturnover#Intention_To_Terminate"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/vt417960/ontologies/2024/0/ontoturnover#hasCause"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/vt417960/ontologies/2024/0/ontoturnover#Involuntary_Turnover_Causes"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/vt417960/ontologies/2024/0/ontoturnover#Turnover"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/vt417960/ontologies/2024/0/ontoturnover#Voluntary_Turnover"/>
    </owl:Class>
    


